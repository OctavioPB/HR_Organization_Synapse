{
  "title": "Org Synapse — Operations",
  "uid": "org-synapse-ops",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["org-synapse"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"org_synapse_api\"}[1m])) by (handler, method)",
          "legendFormat": "{{method}} {{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API Latency p50 / p95 / p99 (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"org_synapse_api\"}[5m])) by (le, handler))",
          "legendFormat": "p50 {{handler}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"org_synapse_api\"}[5m])) by (le, handler))",
          "legendFormat": "p95 {{handler}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"org_synapse_api\"}[5m])) by (le, handler))",
          "legendFormat": "p99 {{handler}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active SPOF Alerts",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "org_synapse_active_spof_alerts_total",
          "legendFormat": "Active SPOF alerts",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "API In-Flight Requests",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress{job=\"org_synapse_api\"})",
          "legendFormat": "In-flight",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "HTTP Error Rate (5xx)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"org_synapse_api\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(org_synapse_cache_hits_total[5m]) / (rate(org_synapse_cache_hits_total[5m]) + rate(org_synapse_cache_misses_total[5m]))",
          "legendFormat": "Hit rate",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    }
  ]
}
