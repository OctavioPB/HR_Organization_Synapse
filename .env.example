# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_COLLAB_EVENTS=collaboration.events.raw

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=org_synapse
POSTGRES_USER=opb
POSTGRES_PASSWORD=changeme

# ─── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://opb:changeme@localhost/airflow
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_SECRET_KEY=org_synapse_dev_secret_change_in_prod

# ─── Graph & ML ───────────────────────────────────────────────────────────────
SILO_THRESHOLD=4.0
SPOF_ALPHA=0.4
SPOF_BETA=0.3
SPOF_GAMMA=0.2
SPOF_DELTA=0.1
ENTROPY_WINDOW_DAYS=30
ENTROPY_SLOPE_THRESHOLD=-0.01
GRAPH_WINDOW_DAYS=30

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ─── Connectors (Sprint 9) ────────────────────────────────────────────────────
# Set ENABLE_* to true to activate each connector. All default to false.

# Slack
ENABLE_SLACK=false
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_POLL_INTERVAL=300
# JSON dict: {"slack_user_id": "employee-uuid", ...}
SLACK_EMPLOYEE_MAP={}

# Microsoft Teams (Azure AD application credentials)
ENABLE_TEAMS=false
TEAMS_TENANT_ID=your-azure-tenant-id
TEAMS_CLIENT_ID=your-azure-client-id
TEAMS_CLIENT_SECRET=your-azure-client-secret
TEAMS_POLL_INTERVAL=600
TEAMS_LOOKBACK_DAYS=1
# JSON dict: {"aad-object-id": "employee-uuid", ...}
TEAMS_EMPLOYEE_MAP={}

# Jira
ENABLE_JIRA=false
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=service-account@yourorg.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECTS=ENG,HR,OPS
JIRA_POLL_INTERVAL=300
# JSON dict: {"jira-account-id": "employee-uuid", ...}
JIRA_EMPLOYEE_MAP={}

# GitHub
ENABLE_GITHUB=false
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
# JSON dict: {"github-login": "employee-uuid", ...}
GITHUB_EMPLOYEE_MAP={}
