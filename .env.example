# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_COLLAB_EVENTS=collaboration.events.raw

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=org_synapse
POSTGRES_USER=opb
POSTGRES_PASSWORD=changeme

# ─── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://opb:changeme@localhost/airflow
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_SECRET_KEY=org_synapse_dev_secret_change_in_prod

# ─── Graph & ML ───────────────────────────────────────────────────────────────
# Isolation-ratio threshold for the silo *detector* (graph/silo_detector.py).
SILO_THRESHOLD=4.0
SPOF_ALPHA=0.4
SPOF_BETA=0.3
SPOF_GAMMA=0.2
SPOF_DELTA=0.1
# SPOF weight perturbation for the robustness bracket (MODEL.md §5.3).
# Employees critical under all perturbations are robust_critical; those critical
# only under the central weights are critical_uncertain (held for review).
SPOF_PERTURB_RANGE=0.15
ENTROPY_WINDOW_DAYS=30
ENTROPY_SLOPE_THRESHOLD=-0.01
GRAPH_WINDOW_DAYS=30

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Redis (API cache) ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0
CACHE_TTL_SEC=3600
CACHE_ENABLED=true

# ─── Observability ────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
# Tune approximate betweenness thresholds (Sprint 10)
BETWEENNESS_EXACT_THRESHOLD=500
BETWEENNESS_K_PIVOTS=200

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
# Must match ADMIN_SECRET_KEY — used by the Admin Panel in the browser
VITE_ADMIN_KEY=change-me-before-production

# ─── Connectors (Sprint 9) ────────────────────────────────────────────────────
# Set ENABLE_* to true to activate each connector. All default to false.

# Slack
ENABLE_SLACK=false
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_POLL_INTERVAL=300
# JSON dict: {"slack_user_id": "employee-uuid", ...}
SLACK_EMPLOYEE_MAP={}

# Microsoft Teams (Azure AD application credentials)
ENABLE_TEAMS=false
TEAMS_TENANT_ID=your-azure-tenant-id
TEAMS_CLIENT_ID=your-azure-client-id
TEAMS_CLIENT_SECRET=your-azure-client-secret
TEAMS_POLL_INTERVAL=600
TEAMS_LOOKBACK_DAYS=1
# JSON dict: {"aad-object-id": "employee-uuid", ...}
TEAMS_EMPLOYEE_MAP={}

# Jira
ENABLE_JIRA=false
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=service-account@yourorg.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECTS=ENG,HR,OPS
JIRA_POLL_INTERVAL=300
# JSON dict: {"jira-account-id": "employee-uuid", ...}
JIRA_EMPLOYEE_MAP={}

# GitHub
ENABLE_GITHUB=false
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
# JSON dict: {"github-login": "employee-uuid", ...}
GITHUB_EMPLOYEE_MAP={}

# ─── Knowledge Risk connectors (F3) ───────────────────────────────────────────
# Set ENABLE_* to true to activate each connector. Both default to false.

# Confluence
ENABLE_CONFLUENCE=false
CONFLUENCE_BASE_URL=https://yourorg.atlassian.net
CONFLUENCE_EMAIL=service-account@yourorg.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
# Comma-separated space keys to ingest (empty = all spaces)
CONFLUENCE_SPACES=ENG,HR,OPS
CONFLUENCE_LOOKBACK_DAYS=7
# JSON dict: {"confluence-account-id": "employee-uuid", ...}
CONFLUENCE_EMPLOYEE_MAP={}

# Notion
ENABLE_NOTION=false
NOTION_API_TOKEN=secret_your-notion-integration-token
NOTION_LOOKBACK_DAYS=7
# JSON dict: {"notion-user-id": "employee-uuid", ...}
NOTION_EMPLOYEE_MAP={}

# ─── Knowledge scoring weights ────────────────────────────────────────────────
# knowledge_score = α_sole * sole_expert_fraction
#                 + α_vol  * normalised_doc_count
#                 + α_brd  * normalised_domain_count
# enhanced_spof = (1 - δ) * graph_spof + δ * knowledge_score
KNOWLEDGE_ALPHA_SOLE=0.5
KNOWLEDGE_ALPHA_VOL=0.3
KNOWLEDGE_ALPHA_BRD=0.2
KNOWLEDGE_DELTA=0.3

# ─── Succession Planning weights (F4) ─────────────────────────────────────────
# compatibility = w_struct * structural_overlap
#               + w_clust  * clustering_score
#               + w_domain * domain_overlap
SUCCESSION_W_STRUCT=0.40
SUCCESSION_W_CLUST=0.25
SUCCESSION_W_DOMAIN=0.35
# structural_overlap uses the normalized weighted Jaccard (MODEL.md §8.1):
# Tanimoto coefficient on proportional interaction weights, removing tenure bias.
# How many top-SPOF employees to generate plans for (per DAG run)
SUCCESSION_TOP_N_SPOF=20
# Candidates per SPOF employee
SUCCESSION_N_CANDIDATES=5
# Minimum SPOF score to qualify as a critical node requiring a succession plan
SUCCESSION_MIN_SPOF_SCORE=0.3

# ─── Real-Time Alert Engine (F5) ──────────────────────────────────────────────
# Internal API key to protect POST /internal/alerts/broadcast from public access.
# Leave empty to disable auth (suitable for network-isolated deployments).
INTERNAL_API_KEY=

# Base URL that Airflow tasks use to call the API (internal network)
API_INTERNAL_URL=http://api:8000

# ─── Multi-Tenant SaaS (F6) ───────────────────────────────────────────────────
# Secret key protecting POST /admin/* endpoints. Leave empty to disable admin API.
ADMIN_SECRET_KEY=change-me-before-production

# Stripe integration (optional — leave empty to disable billing)
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# Kafka topic partitions for tenant topics
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION=1

# Single-tenant mode: set this to use tenant-namespaced Kafka topics from CLI producers
TENANT_SLUG=

# ─── Org Health Score (F9) ────────────────────────────────────────────────────
# Composite score weights (must sum to 1.0)
HEALTH_W_SILO=0.20
HEALTH_W_SPOF=0.35
HEALTH_W_ENTROPY=0.20
HEALTH_W_FRAG=0.25
# Silo risk denominator scales with org structure (MODEL.md §12.1):
# max tolerable silos = floor(num_departments / SILO_THRESHOLD_RATIO), min 2.
# Replaces the deprecated fixed HEALTH_SILO_REF=10.
SILO_THRESHOLD_RATIO=3.0
# Convex fragmentation penalty steepness (MODEL.md §12.2): risk = 1 - exp(-λ·(WCC-1)).
# λ=1.5 ⇒ first disconnection (WCC=2) maps to risk ≈ 0.78.
FRAGMENTATION_LAMBDA=1.5
# Entropy slope magnitude that maps to maximum entropy risk
HEALTH_ENTROPY_SCALE=0.05
# Delivery (optional — leave empty to disable)
SENDGRID_API_KEY=
BRIEFING_EMAIL_TO=
BRIEFING_EMAIL_FROM=noreply@org-synapse.internal
SLACK_BRIEFING_CHANNEL=

# ─── Natural Language Interface (F7) ──────────────────────────────────────────
# Anthropic API key — required for POST /query/natural
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Claude model used by the NL query agent
CLAUDE_MODEL=claude-sonnet-4-6
# Maximum agent reasoning turns per query (each turn may call tools)
NL_MAX_TURNS=6

# ─── Onboarding Integration (MODEL.md §9) ─────────────────────────────────────
# Tenure day at which the onboarding alert fires.
ONBOARDING_ALERT_DAY=60
# Min CS_overlap (Jaccard of community membership across weeks) for a new-hire
# cohort to count as structurally stable.
CS_OVERLAP_THRESHOLD=0.6

# ─── Turnover Contagion alert layer (MODEL.md §7.4.1) ─────────────────────────
# Trailing window (days) over which peer departures are counted.
PEER_CHURN_WINDOW_DAYS=180
# peer_churn_rate above this fraction fires a peer_contagion_risk alert.
PEER_CONTAGION_THRESHOLD=0.30

# ─── Churn explainability (MODEL.md §7.4.2) ───────────────────────────────────
# Number of top-attention neighbors surfaced per employee.
CHURN_INFLUENCE_TOP_K=3

# ─── Structural Equity (MODEL.md §11.1) ───────────────────────────────────────
# Disparity ratio that triggers a below_org_median investigation flag.
# Heuristic (adapted by analogy from the EEOC 4/5ths rule) — NOT a legal standard.
EQUITY_DISPARITY_RATIO=0.8
